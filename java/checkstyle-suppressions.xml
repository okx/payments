<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
    "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
    "https://checkstyle.org/dtds/suppressions_1_2.dtd">

<suppressions>
  <!-- Suppress visibility checks on model/POJO classes -->
  <suppress checks="VisibilityModifier" files=".*[/\\]model[/\\].*\.java"/>
  <suppress checks="VisibilityModifier" files=".*[/\\]client[/\\](VerificationResponse|SettlementResponse|Kind)\.java"/>
  <suppress checks="VisibilityModifier" files=".*[/\\]server[/\\]PaymentFilter\.java"/>
</suppressions>
